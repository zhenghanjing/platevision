# Copy this file to `.env` (which is gitignored) and fill in your own key.
# Get a free personal key at https://fdc.nal.usda.gov/api-key-signup.html
# If left unset, estimation/fdc_client.py falls back to api.data.gov's
# shared "DEMO_KEY", which works but is rate-limited (30 req/hour, 50/day)
# and shared across everyone using it -- fine for a quick look, not for
# real use.
FDC_API_KEY=
